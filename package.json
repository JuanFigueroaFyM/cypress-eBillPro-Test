{
  "name": "cypress-ebillpro-test",
  "version": "2.0.0",
  "description": "Pruebas E2E — eBill Pro Go (Arquitectura POM + i18n + factories)",
  "private": true,
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:headless": "cypress run --headless --browser chrome",
    "cy:run:auth": "cypress run --spec 'cypress/e2e/auth/**/*.cy.js'",
    "cy:run:docs": "cypress run --spec 'cypress/e2e/documents/**/*.cy.js'",
    "cy:run:clients": "cypress run --spec 'cypress/e2e/clients/**/*.cy.js'",
    "cy:run:nuevo-doc": "cypress run --spec 'cypress/e2e/documents/nuevo-documento.cy.js'",
    "cy:run:smoke": "cypress run --env grepTags=@smoke",
    "cy:run:regression": "cypress run --env grepTags=@regression",
    "cy:run:critical": "cypress run --env grepTags=@critical",
    "cy:record": "cypress run --record --key $CYPRESS_RECORD_KEY",
    "cy:env:dev": "CYPRESS_ENV=dev cypress run",
    "cy:env:test": "CYPRESS_ENV=test cypress run",
    "lint": "eslint 'cypress/**/*.js' --max-warnings=0",
    "lint:fix": "eslint 'cypress/**/*.js' --fix",
    "format": "prettier --write 'cypress/**/*.{js,json}' 'config/**/*.json' '*.{js,json,md}'",
    "format:check": "prettier --check 'cypress/**/*.{js,json}' 'config/**/*.json' '*.{js,json,md}'",
    "verify": "npm run lint && npm run format:check"
  },
  "devDependencies": {
    "@cypress/grep": "^4.0.1",
    "cypress": "^13.0.0",
    "cypress-mochawesome-reporter": "^3.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^2.15.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
