# ────────────────────────────────────────────────────────────────────────────
# Dependencias
# ────────────────────────────────────────────────────────────────────────────
node_modules/

# ────────────────────────────────────────────────────────────────────────────
# Cypress — artefactos de ejecución (regenerables, NO deben ir al repo)
# ────────────────────────────────────────────────────────────────────────────
cypress/screenshots/
cypress/videos/
cypress/reports/
cypress/downloads/
cypress/results/

# ────────────────────────────────────────────────────────────────────────────
# Secretos y variables de entorno locales
#   cypress.env.json contiene credenciales reales — NUNCA al repo.
#   Usar cypress.env.example.json como plantilla.
# ────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
cypress.env.json

# ────────────────────────────────────────────────────────────────────────────
# Editor / SO
# ────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json

# ────────────────────────────────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
